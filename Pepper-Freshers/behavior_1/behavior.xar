class MyClass(GeneratedClass):
    def __init__(self):
        GeneratedClass.__init__(self)
        self.motion = ALProxy("ALMotion")
        pass

    def onLoad(self):
        pass

    def onUnload(self):
        self.motion.moveToward(0.0, 0.0, 0.0)

    def onInput_onStart(self):
        self.motion.moveTo([self.getParameter("X"), self.getParameter("Y"), self.getParameter("Turns")*2.0*pi, self.getParameter("Time")], [["MaxVelXY", self.getParameter("Max Velocity")], ["MaxAccXY", self.getParameter("Max Acceleration")], ["MaxJerkXY", self.getParameter("Max Jerk")]])
        self.onStopped()

    def onInput_onStop(self):
        self.onUnload()</content></script><Input name="onLoad" type="1" type_size="1" nature="0" inner="1" tooltip="Signal sent when diagram is loaded." id="1"/><Input name="onStart" type="1" type_size="1" nature="2" inner="0" tooltip="Box behavior starts when a signal is received on this input." id="2"/><Input name="onStop" type="1" type_size="1" nature="3" inner="0" tooltip="Box behavior stops when a signal is received on this input." id="3"/><Output name="onStopped" type="1" type_size="1" nature="1" inner="0" tooltip="Signal sent when box behavior is finished." id="4"/><Parameter name="X" inherits_from_parent="0" content_type="2" value="0" default_value="0" min="-5" max="5" tooltip="" id="5"/><Parameter name="Y" inherits_from_parent="0" content_type="2" value="0" default_value="0" min="-5" max="5" tooltip="" id="6"/><Parameter name="Turns" inherits_from_parent="0" content_type="2" value="1" default_value="0" min="-5" max="5" tooltip="" id="7"/><Parameter name="Time" inherits_from_parent="0" content_type="2" value="8" default_value="1" min="0" max="10" tooltip="" id="8"/><Parameter name="Max Velocity" inherits_from_parent="0" content_type="2" value="0.35" default_value="0.35" min="0.1" max="0.35" tooltip="" id="9"/><Parameter name="Max Acceleration" inherits_from_parent="0" content_type="2" value="0.3" default_value="0.3" min="0.1" max="0.3" tooltip="" id="10"/><Parameter name="Max Jerk" inherits_from_parent="0" content_type="2" value="1" default_value="1" min="0.2" max="1" tooltip="" id="11"/></Box><Link inputowner="3" indexofinput="2" outputowner="0" indexofoutput="1"/></Diagram></BehaviorKeyframe></BehaviorLayer><ActuatorList model="juliette"><ActuatorCurve name="value" actuator="HeadPitch" mute="0" unit="0"><Key frame="1" value="-16.0088"/><Key frame="7" value="-16.0088"><Tangent side="left" interpType="linear" abscissaParam="0" ordinateParam="0"/><Tangent side="right" interpType="linear" abscissaParam="0" ordinateParam="0"/></Key><Key frame="14" value="-27.64