Move To with time constraint, and fixed max speed, max acceleration and jerk in XY and Theta" x="453" y="79"><bitmap>media/images/box/movement/walk_forward.png</bitmap><script language="4"><content>from math import pi
class MyClass(GeneratedClass):
    def __init__(self):
        GeneratedClass.__init__(self)
        self.motion = ALProxy("ALMotion")
        pass

    def onLoad(self):
        pass

    def onUnload(self):
        self.motion.moveToward(0.0, 0.0, 0.0)

    def onInput_onStart(self):
        self.motion.moveTo([self.getParameter("X"), self.getParameter("Y"), self.getParameter("Turns")*2.0*pi, self.getParameter("Time")], [["MaxVelXY", self.getParameter("Max Velocity")], ["MaxAccXY", self.getParameter("Max Acceleration")], ["MaxJerkXY", self.getParameter("Max Jerk")], ["MaxVelTheta", self.getParameter("Max Velocity Theta")], ["MaxAccTheta", self.getParameter("Max Acceleration Theta")], ["MaxJerkTheta", self.getParameter("Max Jerk Theta")]])
        self.onStopped()

    def onInput_onStop(self):
        self.onUnload()</content></script><Input name="onLoad" type="1" type_size="1" nature="0" inner="1" tooltip="Signal sent when diagram is loaded." id="1"/><Input name="onStart" type="1" type_size="1" nature="2" inner="0" tooltip="Box behavior starts when a signal is received on this input." id="2"/><Input name="onStop" type="1" type_size="1" nature="3" inner="0" tooltip="Box behavior stops when a signal is received on this input." id="3"/><Output name="onStopped" type="1" type_size="1" nature="1" inner="0" tooltip="Signal sent when box behavior is finished." id="4"/><Parameter name="X" inherits_from_parent="0" content_type="2" value="0" default_value="0" min="-5" max="5" tooltip="" id="5"/><Parameter name="Y" inherits_from_parent="0" content_type="2" value="0.5" default_value="0" min="-5" max="5" tooltip="" id="6"/><Parameter name="Turns" inherits_from_parent="0" content_type="2" value="0.5" default_value="0" min="-5" max="5" tooltip="" id="7"/><Parameter name="Time" inherits_from_parent="0" content_type="2" value="3" default_value="1" min="0" max="10" tooltip="" id="8"/><Parameter name="Max Velocity" inherits_from_parent="0" content_type="2" value="0.83" default_value="0.35" min="0.1" max="0.83" tooltip="" id="9"/><Parameter name="Max Acceleration" inherits_from_parent="0" content_type="2" value="1" default_value="0.3" min="0.1" max="1" tooltip="" id="10"/><Parameter name="Max Jerk" inherits_from_parent="0" content_type="2" value="1" default_value="1" min="0.2" max="1" tooltip="" id="11"/><Parameter name="Max Velocity Theta" inherits_from_parent="0" content_type="2" value="2.4" default_value="1" min="0.2" max="2.4" tooltip="" id="12"/><Parameter name="Max Acceleration Theta" inherits_from_parent="0" content_type="2" value="1" default_value="0.75" min="0.1" max="1" tooltip="" id="13"/><Parameter name="Max Jerk Theta" inherits_from_parent="0" content_type="2" value="10" default_value="2" min="0.2" max="10" tooltip="" id="14"/></Box><Link inputowner="4" indexofinput="2" outputowner="0" indexofoutput="1"/></Diagram></BehaviorKeyframe><BehaviorKeyframe name="keyframe91_copy" index="186"><Diagram><Box name="Move Toward" id="3" localization="3" tooltip="Make NAO move in the direction you set in parameters.&#10;&#10;!!Warning!! NAO will not stop moving by himself. You need to either set x, y and theta to 0 or stop the box to stop him.&#10;&#10;Note: You can set the period of move direction update in parameters." x="365" y="177"><bitmap>media/images/box/movement/walk_forward.png</bitmap><script language="4"><content>import time
import math

class MyClass(GeneratedClass):
    def __init__(self):
        try: # disable autoBind
          GeneratedClass.__init__(self, False)
        except TypeError: # if NAOqi &lt; 1.14
          GeneratedClass.__init__( self )
        self.motion = ALProxy("ALMotion")

    def onLoad(self):
        self.x = 0
        self.y = 0
        self.theta = 0

    def onUnload(self):
        self.mustStop = True

    def onInput_onStop(self):
        self.mustStop = True

    def onInput_onStart(self):
        self.mustStop = False
        while( not self.mustStop ):
            time.sleep(self.getParameter("Period of direction update (s)"))
            x = self.getParameter("X")
            y = self.getParameter("Y")
            theta = self.getParameter("Theta")
            epsilon = 0.0001
            dx = math.fabs(x - self.x)
            dy = math.fabs(y - self.y)
            dt = math.fabs(theta - self.theta)
            if(dx &gt; epsilon or dy &gt; epsilon or dt &gt; epsilon):
                self.x=x
                self.y=y
                self.theta=theta
                self.move()
        self.x = 0
        self.y = 0
        self.theta = 0
        self.move()
        self.motion.waitUntilMoveIsFinished()
        self.onStopped()

    def move(self):
        moveConfig=[["MaxVelTheta", 2.4],["MaxAccTheta", 3.0]]
        #moveConfig=[["MaxVelTheta", 2.4],["MaxAccTheta", 3.0]]
        self.motion.moveToward(self.x, self.y, self.theta, moveConfig)</content></script><Input name="onLoad" type="1" type_size="1" nature="0" inner="1" tooltip="Signal sent when Diagram is loaded." id="1"/><Input name="onStart" type="1" type_size="1" nature="2" inner="0" tooltip="Box behavior starts when a signal is received on this input." id="2"/><Input name="onStop" type="1" type_size="1" nature="3" inner="0" tooltip="Box behavior stops when a signal is received on this input." id="3"/><Output name="onStopped" type="1" type_size="1" nature="1" inner="0" tooltip="" id="4"/><Parameter name="X" inherits_from_parent="0" content_type="2" value="1" default_value="0.2" min="-1" max="1" tooltip="The distance in meters for forward/backward motion. Positive value&#10;means forward, negative value means backward." id="5"/><Parameter name="Y" inherits_from_parent="0" content_type="2" value="0" default_value="0" min="-1" max="1" tooltip="The distance in meters for lateral motion. Positive value means left, negative&#10;value means right." id="6"/><Parameter name="Theta" inherits_from_parent="0" content_type="2" value="1" default_value="0" min="-1" max="1" tooltip="The orientation in radians for final rotation. Positive value means anticlockwise,&#10;negative value means clockwise." id="7"/><Parameter name="Period of direction update (s)" inherits_from_parent="0" content_type="2" value="0.1" default_value="0.1" min="0" max="1" tooltip="" id="8"/><Resource name="Legs" type="Lock" timeout="0"/></Box><Box name="Wait" id="1" localization="8" tooltip="Wait a moment before sending a signal on the output. The wait can be stopped any&#10;time. You may restart it any time, and it will start again." x="208" y="148"><bitmap>media/images/box/wait.png</bitmap><script language="4"><content>import threading

class MyClass(GeneratedClass):
    def __init__(self):
        try: # disable autoBind
          GeneratedClass.__init__(self, False)
        except TypeError: # if NAOqi &lt; 1.14
          GeneratedClass.__init__( self )

    def onLoad(self):
        self.tb = False

    def onUnload(self):
        if( self.tb ):
            self.tb.cancel()
            self.tb = False

    def triggerOutput( self, rPeriod = 1 ):
        self.onUnload() # to clean everything
        self.timerOutput()

    def startTimer( self, rPeriod = 1 ):
        if( self.tb ):
            self.tb.cancel()
        self.tb = threading.Timer( rPeriod, self.triggerOutput, [rPeriod] )
        self.tb.start()

    def onInput_onStart(self):
        self.startTimer( self.getParameter("Timeout (s)") )

    def onInput_onStop(self):
        bRunning = self.tb
        self.onUnload()
        if( bRunning and self.getParameter("Trigger timerOutput if cancelled")):
            self.timerOutput()</content></script><Input name="onLoad" type="1" type_size="1" nature="0" inner="1" tooltip="Signal sent when diagram is loaded." id="1"/><Input name="onStart" type="1" type_size="1" nature="2" inner="0" tooltip="Start the Wait box with the configured timeout value." id="2"/><Input name="onStop" type="1" type_size="1" nature="3" inner="0" tooltip="Stop the wait and stimulate the output." id="3"/><Output name="timerOutput" type="1" type_size="1" nature="1" inner="0" tooltip="Send a bang once time set in parameters is ellapsed, or if the box is stopped." id="4"/><Parameter name="Timeout (s)" inherits_from_parent="0" content_type="2" value="0.9" default_value="1" min="0" max="5000" tooltip="Duration the box waits before stimulating the output." id="5"/><Parameter name="Trigger timerOutput if cancelled" inherits_from_parent="0" content_type="0" value="0" default_value="1" tooltip="" id="6"/></Box><Box name="Move To " id="2" localization="8" tooltip="Move To with time constraint, and fixed max speed, max acceleration and jerk" x="640" y="137"><bitmap>media/images/box/movement/walk_forward.png</bitmap><script language="4"><content>from math import pi
