              <Input name="onStop" type="1" type_size="1" nature="3" inner="0" tooltip="Box behavior stops when a signal is received on this input." id="3" />
              <Output name="onTouched" type="0" type_size="1" nature="2" inner="0" tooltip="Send [x,y] position for one touch" id="4" />
              <Parameter name="Action" inherits_from_parent="0" content_type="3" value="On touch move" default_value="On touch move" custom_choice="0" tooltip="Type of touch you want on the tablet." id="5">
                <Choice value="On touch move" />
                <Choice value="On touch down" />
